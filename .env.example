# Apex Contracts — environment overrides
# Copy this file to `.env` on the server (same folder as docker-compose.yml):
#     cp .env.example .env   &&   nano .env
# `.env` is gitignored, so real secrets never get committed. Docker Compose
# reads it automatically; the webhook's `docker compose up -d --build` applies it.
# Anything you leave commented falls back to the default baked into docker-compose.yml.

# ── AI provider: ollama (local, default) | anthropic | openai ──
# AI_PROVIDER=ollama

# ── Local Ollama (used when AI_PROVIDER=ollama) ──
# OLLAMA_HOST=http://13.0.2.47:11435
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_NUM_CTX=8192
# EMBED_MODEL=nomic-embed-text

# ── Anthropic (used when AI_PROVIDER=anthropic) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── OpenAI (used when AI_PROVIDER=openai) ──
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-5.4-mini
